# VAST Audit Log Dashboards — Configuration
# Copy this file to .env and edit for your environment:
#   cp .env.example .env

# ─── Trino Connection (required) ───────────────────────────────────────────────
# URL of your Trino instance with the VAST connector.
# If Grafana and Trino run on the same host, use http://host.docker.internal:8080
# If Trino is on a remote host, use http://<trino-host>:<port>
TRINO_URL=http://host.docker.internal:8080

# Trino catalog name for your VAST cluster (default: vast)
TRINO_CATALOG=vast

# Trino username (default: grafana)
TRINO_USER=grafana

# Trino password (leave empty if no auth)
TRINO_PASSWORD=

# ─── Grafana (optional) ───────────────────────────────────────────────────────
# Port Grafana listens on (default: 3000)
GRAFANA_PORT=3000
